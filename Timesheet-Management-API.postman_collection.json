{
  "info": {
    "_postman_id": "timesheet-management-system",
    "name": "Timesheet Management System API",
    "description": "Complete API collection for Timesheet Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Timesheets",
      "item": [
        {
          "name": "Create Timesheet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"timesheet_id\", jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weekStartDate\": \"2024-03-25\",\n  \"weekEndDate\": \"2024-03-31\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/timesheets",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets"]
            }
          }
        },
        {
          "name": "Add Timesheet Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workDate\": \"2024-03-25\",\n  \"hoursWorked\": 8.5,\n  \"task\": \"Implemented user authentication\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/timesheets/{{timesheet_id}}/entries",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "{{timesheet_id}}", "entries"]
            }
          }
        },
        {
          "name": "Get My Timesheets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/timesheets/my",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "my"]
            }
          }
        },
        {
          "name": "Get Timesheet by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/timesheets/{{timesheet_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "{{timesheet_id}}"]
            }
          }
        },
        {
          "name": "Submit Timesheet",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/timesheets/{{timesheet_id}}/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "{{timesheet_id}}", "submit"]
            }
          }
        },
        {
          "name": "Approve Timesheet",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/timesheets/{{timesheet_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "{{timesheet_id}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Timesheet",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Missing entries for some days\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/timesheets/{{timesheet_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "{{timesheet_id}}", "reject"]
            }
          }
        },
        {
          "name": "Get Pending Timesheets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/timesheets/pending",
              "host": ["{{base_url}}"],
              "path": ["api", "timesheets", "pending"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "timesheet_id",
      "value": "",
      "type": "string"
    }
  ]
}
